/* pages/settings/index.wxss */
.settings-page {
  padding: 40rpx 32rpx;
  min-height: 100vh;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.section-title {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 24rpx;
  font-weight: 900;
  letter-spacing: 2rpx;
}

.setting-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border-radius: 28rpx;
  padding: 36rpx 36rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.setting-row-left {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.setting-row-right {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.setting-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
}
.dot-sound { background: #FF9F1C; }
.dot-vibration { background: #4D96FF; }

.setting-label {
  font-size: 34rpx;
  font-weight: 900;
  color: #333;
}

.try-btn {
  font-size: 26rpx;
  font-weight: 900;
  color: #FFB300;
  margin-right: 24rpx;
  padding: 8rpx 20rpx;
  border: 2rpx solid #FFD76A;
  border-radius: 28rpx;
}
.try-btn:active {
  background: #FFF5D6;
}

/* About section */
.about-section {
  margin-top: auto;
  padding: 64rpx 0 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.about-slogan {
  font-size: 28rpx;
  font-weight: 900;
  color: #CCBF99;
}
.about-version {
  font-size: 22rpx;
  color: #CCC;
  margin-top: 12rpx;
}

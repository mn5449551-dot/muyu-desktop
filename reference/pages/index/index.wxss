/* pages/index/index.wxss */

/* Override global page bg/height for this page */
page {
  height: 100%;
}

/* ── Layout ─────────────────────────────── */
.page {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  overflow: hidden;
  background: #FFFCEE;
  touch-action: manipulation;
}

.toolbar {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 16rpx 32rpx;
  flex-shrink: 0;
}
.toolbar-char {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  background: #FFD76A;
}
.toolbar-char-name {
  font-size: 28rpx;
  font-weight: 900;
  color: #333;
  margin-left: 12rpx;
}
.toolbar-spacer { flex: 1; }
.toolbar-setting {
  font-size: 44rpx;
  line-height: 1;
  opacity: 1;
}

/* Shake wrapper */
.shake-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: visible;
}

/* Character */
.char-touch {
  display: flex;
  align-items: center;
  justify-content: center;
  touch-action: manipulation;
}
.char-img {
  width: 420rpx;
  height: 420rpx;
  display: block;
}

/* Counter */
.counter-area {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: 16rpx;
  position: relative;
}
.count-inner {
  display: flex;
  flex-direction: row;
  align-items: baseline;
}
.count-num {
  font-size: 80rpx;
  font-weight: 900;
  color: #333;
  line-height: 1;
}
.count-label {
  font-size: 32rpx;
  font-weight: 900;
  color: #999;
  margin-left: 8rpx;
}

/* Progress bar */
.progress-track {
  width: 480rpx;
  height: 8rpx;
  border-radius: 4rpx;
  background: #FFEDB0;
  margin-top: 12rpx;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  border-radius: 4rpx;
  background: #FFD76A;
  transition: width 0.3s ease;
}

/* Progress hint */
.progress-hint {
  font-size: 22rpx;
  color: #BBB;
  font-weight: 900;
  margin-top: 8rpx;
}

/* Milestone badge */
.badge {
  position: absolute;
  top: -20rpx;
  left: 50%;
  transform: translateX(-50%);
  background: #FF6B6B;
  color: #fff;
  font-size: 30rpx;
  font-weight: 900;
  padding: 8rpx 28rpx;
  border-radius: 40rpx;
  white-space: nowrap;
  pointer-events: none;
}

/* Share button */
.share-btn {
  align-self: center;
  margin: 0 auto 48rpx;
  width: 480rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: #FFD76A;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 900;
  color: #333;
  text-align: center;
  border: none;
  flex-shrink: 0;
  box-shadow:
    inset 0 -4rpx 0 rgba(0,0,0,0.15),
    0 4rpx 12rpx rgba(255,215,106,0.5);
  transition: transform 0.1s, box-shadow 0.1s;
}
.share-btn::after { border: none; }
.share-btn:active {
  transform: translateY(2rpx);
  box-shadow: inset 0 -2rpx 0 rgba(0,0,0,0.15);
}

/* ── Float text ─────────────────────────── */
.float-text {
  position: absolute;
  font-size: 36rpx;
  font-weight: 900;
  white-space: nowrap;
  pointer-events: none;
  transform-origin: center;
  animation: float-up 1.5s ease-out forwards;
  z-index: 10;
  text-shadow: 0 2px 6px rgba(0,0,0,0.15);
}

/* ── Particles ──────────────────────────── */
.particle {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
  animation-duration: 0.8s;
  animation-timing-function: ease-out;
  animation-fill-mode: forwards;
}
.p-fly-0 { animation-name: p-fly-0; }
.p-fly-1 { animation-name: p-fly-1; }
.p-fly-2 { animation-name: p-fly-2; }
.p-fly-3 { animation-name: p-fly-3; }
.p-fly-4 { animation-name: p-fly-4; }
.p-fly-5 { animation-name: p-fly-5; }
.p-fly-6 { animation-name: p-fly-6; }
.p-fly-7 { animation-name: p-fly-7; }

/* ── Keyframes ──────────────────────────── */

/* Full-screen shake (A/B pair) */
@keyframes shake-anim-a {
  0%   { transform: translateX(0); }
  20%  { transform: translateX(-4px); }
  45%  { transform: translateX(4px); }
  65%  { transform: translateX(-2px); }
  82%  { transform: translateX(2px); }
  100% { transform: translateX(0); }
}
@keyframes shake-anim-b {
  0%   { transform: translateX(0); }
  20%  { transform: translateX(-4px); }
  45%  { transform: translateX(4px); }
  65%  { transform: translateX(-2px); }
  82%  { transform: translateX(2px); }
  100% { transform: translateX(0); }
}
.shake-anim-a { animation: shake-anim-a 0.25s ease-out; }
.shake-anim-b { animation: shake-anim-b 0.25s ease-out; }

/* Character squeeze/bounce (A/B pair) */
@keyframes squeeze-anim-a {
  0%   { transform: scaleX(1) scaleY(1); }
  15%  { transform: scaleX(1.22) scaleY(0.75); }
  100% { transform: scaleX(1) scaleY(1); }
}
@keyframes squeeze-anim-b {
  0%   { transform: scaleX(1) scaleY(1); }
  15%  { transform: scaleX(1.22) scaleY(0.75); }
  100% { transform: scaleX(1) scaleY(1); }
}
.squeeze-anim-a {
  animation: squeeze-anim-a 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
}
.squeeze-anim-b {
  animation: squeeze-anim-b 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
}

/* Float text rising */
@keyframes float-up {
  0%   { transform: translateY(0); opacity: 1; }
  100% { transform: translateY(-60px); opacity: 0; }
}

/* Badge pop */
@keyframes badge-pop {
  0%   { transform: translateX(-50%) scale(0); opacity: 0; }
  60%  { transform: translateX(-50%) scale(1.2); opacity: 1; }
  100% { transform: translateX(-50%) scale(1); opacity: 1; }
}
.badge-pop { animation: badge-pop 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) forwards; }

/* Counter shake on milestone (A/B pair) */
@keyframes count-shake-a {
  0%   { transform: scale(1) rotate(0deg); }
  20%  { transform: scale(1.3) rotate(-6deg); }
  50%  { transform: scale(1.3) rotate(6deg); }
  80%  { transform: scale(1.15) rotate(-3deg); }
  100% { transform: scale(1) rotate(0deg); }
}
@keyframes count-shake-b {
  0%   { transform: scale(1) rotate(0deg); }
  20%  { transform: scale(1.3) rotate(-6deg); }
  50%  { transform: scale(1.3) rotate(6deg); }
  80%  { transform: scale(1.15) rotate(-3deg); }
  100% { transform: scale(1) rotate(0deg); }
}
.count-shake-a { animation: count-shake-a 0.6s cubic-bezier(0.34, 1.56, 0.64, 1); }
.count-shake-b { animation: count-shake-b 0.6s cubic-bezier(0.34, 1.56, 0.64, 1); }

/* ── Character switch animation ─────────── */
@keyframes switch-squish-out {
  0%   { transform: scaleX(1); }
  100% { transform: scaleX(0); }
}
@keyframes switch-expand-in {
  0%   { transform: scaleX(0); }
  100% { transform: scaleX(1); }
}
.switch-squish-out { animation: switch-squish-out 0.15s ease-in forwards; }
.switch-expand-in  { animation: switch-expand-in  0.15s ease-out forwards; }

/* ── Unlock modal ───────────────────────── */
.unlock-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}
.unlock-modal {
  background: #FFFCEE;
  border-radius: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 64rpx 40rpx;
  width: 560rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.2);
}
@keyframes unlock-pop {
  0%   { transform: scale(0.4); opacity: 0; }
  70%  { transform: scale(1.08); opacity: 1; }
  100% { transform: scale(1); opacity: 1; }
}
.unlock-modal-pop { animation: unlock-pop 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) forwards; }
.unlock-emoji {
  font-size: 72rpx;
  line-height: 1;
  margin-bottom: 16rpx;
}
.unlock-title {
  font-size: 40rpx;
  font-weight: 900;
  color: #333;
  margin-bottom: 24rpx;
}
.unlock-img {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 16rpx;
}
.unlock-name {
  font-size: 36rpx;
  font-weight: 900;
  color: #555;
  margin-bottom: 32rpx;
}
.unlock-close {
  width: 360rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: #FFD76A;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 900;
  color: #333;
  text-align: center;
  box-shadow:
    inset 0 -4rpx 0 rgba(0,0,0,0.15),
    0 4rpx 12rpx rgba(255,215,106,0.5);
}

/* 8-direction particle animations */
@keyframes p-fly-0 {
  0%   { transform: translate(0, 0) scale(1); opacity: 1; }
  100% { transform: translate(0, -140px) scale(0); opacity: 0; }
}
@keyframes p-fly-1 {
  0%   { transform: translate(0, 0) scale(1); opacity: 1; }
  100% { transform: translate(100px, -100px) scale(0); opacity: 0; }
}
@keyframes p-fly-2 {
  0%   { transform: translate(0, 0) scale(1); opacity: 1; }
  100% { transform: translate(140px, 0) scale(0); opacity: 0; }
}
@keyframes p-fly-3 {
  0%   { transform: translate(0, 0) scale(1); opacity: 1; }
  100% { transform: translate(100px, 100px) scale(0); opacity: 0; }
}
@keyframes p-fly-4 {
  0%   { transform: translate(0, 0) scale(1); opacity: 1; }
  100% { transform: translate(0, 140px) scale(0); opacity: 0; }
}
@keyframes p-fly-5 {
  0%   { transform: translate(0, 0) scale(1); opacity: 1; }
  100% { transform: translate(-100px, 100px) scale(0); opacity: 0; }
}
@keyframes p-fly-6 {
  0%   { transform: translate(0, 0) scale(1); opacity: 1; }
  100% { transform: translate(-140px, 0) scale(0); opacity: 0; }
}
@keyframes p-fly-7 {
  0%   { transform: translate(0, 0) scale(1); opacity: 1; }
  100% { transform: translate(-100px, -100px) scale(0); opacity: 0; }
}

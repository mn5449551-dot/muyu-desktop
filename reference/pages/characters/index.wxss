/* pages/characters/index.wxss */
.chars-page {
  padding: 32rpx 24rpx;
}

.grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  justify-content: center;
  gap: 24rpx;
}

.card {
  width: calc(50% - 36rpx);
  margin: 0 12rpx;
  border-radius: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 16rpx 24rpx;
  border: 3rpx solid rgba(0,0,0,0.06);
  box-shadow:
    inset -2rpx -2rpx 8rpx rgba(0,0,0,0.08),
    0 8rpx 24rpx rgba(0,0,0,0.12);
  transition: transform 0.2s;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

.card--selected {
  box-shadow:
    0 0 0 6rpx #FFD76A,
    inset -2rpx -2rpx 8rpx rgba(0,0,0,0.08),
    0 8rpx 24rpx rgba(0,0,0,0.12);
  transform: rotate(0deg) !important;
}

.card-check {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 44rpx;
  height: 44rpx;
  line-height: 44rpx;
  text-align: center;
  background: #FFD76A;
  color: #333;
  font-size: 28rpx;
  font-weight: 900;
  border-radius: 50%;
  z-index: 2;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.15);
}

/* Locked card shake */
@keyframes card-shake {
  0%   { transform: translateX(0); }
  25%  { transform: translateX(-6rpx); }
  50%  { transform: translateX(6rpx); }
  75%  { transform: translateX(-4rpx); }
  100% { transform: translateX(0); }
}
.card--shake {
  animation: card-shake 0.2s ease-out;
}

.card-img {
  width: 180rpx;
  height: 180rpx;
}

.card-name {
  margin-top: 16rpx;
  font-size: 30rpx;
  font-weight: 900;
  color: #333;
}

.card--locked {
  filter: grayscale(80%);
  opacity: 0.75;
}

.lock-overlay {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.18);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 28rpx;
}

.lock-icon {
  font-size: 52rpx;
  line-height: 1;
  margin-bottom: 8rpx;
}

.lock-need {
  font-size: 24rpx;
  font-weight: 900;
  color: #fff;
  text-shadow: 0 1px 4px rgba(0,0,0,0.5);
  white-space: nowrap;
}

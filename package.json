{
  "name": "muyu-desktop",
  "version": "0.1.0",
  "description": "戳它，然后看它出丑 — 桌面版",
  "main": "src/main/main.js",
  "scripts": {
    "start:vite": "vite",
    "start:electron": "wait-on tcp:5173 && electron .",
    "dev": "concurrently -k \"npm run start:vite\" \"npm run start:electron\"",
    "build:renderer": "vite build",
    "build:mac": "npm run build:renderer && electron-builder --mac dmg --publish never",
    "build:win": "npm run build:renderer && electron-builder --win zip --publish never",
    "build": "npm run build:renderer && electron-builder",
    "release:check": "npm run build:renderer && npm run test:e2e -- --grep \"voice recording locks send action until recognition finalized|hide all windows then restore main window works\"",
    "rebuild-native": "electron-rebuild -f -w better-sqlite3",
    "test:e2e": "playwright test -c playwright.e2e.config.js",
    "test:e2e:debug": "PWDEBUG=1 playwright test -c playwright.e2e.config.js"
  },
  "build": {
    "appId": "com.muyu.desktop",
    "productName": "木鱼桌宠",
    "icon": "build-resources/icon.png",
    "directories": {
      "buildResources": "build-resources",
      "output": "dist-electron"
    },
    "files": [
      "src/main/**/*",
      "src/shared/**/*",
      "src/utils/**/*",
      "dist/renderer/**/*"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets"
      }
    ],
    "mac": {
      "icon": "build-resources/icon.icns",
      "artifactName": "muyu-desktop-mac-${arch}.${ext}",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "win": {
      "icon": "build-resources/icon.ico",
      "artifactName": "muyu-desktop-win-${arch}.${ext}",
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "30.5.1",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "playwright": "^1.52.0",
    "vite": "^6.0.7",
    "wait-on": "^8.0.1"
  },
  "dependencies": {
    "better-sqlite3": "^11.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.19.0"
  }
}
